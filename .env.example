# ═══════════════════════════════════════════════════════════════════════════
# ExpatCarBuyers — Backend Environment Template
# Copy to .env and fill in your values. NEVER commit .env to version control.
#
# Production checklist:
#   APP_ENV=production  APP_DEBUG=false  APP_KEY=<generated>
#   DB_PORT=5432  SESSION_DRIVER=redis  CACHE_STORE=redis  QUEUE_CONNECTION=redis
#   REDIS_PASSWORD=<strong password>
#   MEILISEARCH_KEY=<rotate master key>
#   SANCTUM_STATEFUL_DOMAINS=www.expatcarbuyers.com,expatcarbuyers.com
# ═══════════════════════════════════════════════════════════════════════════

# ─── Application ────────────────────────────────────────────────────────────
APP_NAME=ExpatCarBuyers
APP_ENV=local                    # production: production
APP_KEY=                         # Run: php artisan key:generate
APP_DEBUG=true                   # production: false
APP_TIMEZONE=Asia/Dubai
APP_URL=http://localhost:8000    # production: https://api.expatcarbuyers.com

# URL used by Next.js Server Components to call the API over the
# private/internal network (fast, no public round-trip).
# production: http://127.0.0.1:8000  (same server, loopback)
INTERNAL_API_URL=http://127.0.0.1:8000

# Public-facing frontend URL (CORS, redirects, password-reset emails)
# production: https://www.expatcarbuyers.com
FRONTEND_URL=http://localhost:3000

# ─── Localization ────────────────────────────────────────────────────────────
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                  # production: error

# ─── Database (PostgreSQL 16) ────────────────────────────────────────────────
# Dev: Docker container on 5433 | Production: Forge-managed Postgres on 5432
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5433                     # production: 5432
DB_DATABASE=expatcar_local       # production: forge (Forge default) or expatcarbuyers
DB_USERNAME=postgres             # production: forge
DB_PASSWORD=123                  # production: <strong generated password>

# ─── Sessions ────────────────────────────────────────────────────────────────
# production: redis  (required for sticky sessions across PM2 workers)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null              # production: .expatcarbuyers.com

# ─── Cache ───────────────────────────────────────────────────────────────────
# production: redis
CACHE_STORE=database
CACHE_PREFIX=expatcar_

# ─── Queue ───────────────────────────────────────────────────────────────────
# production: redis  (processed by Laravel Horizon)
QUEUE_CONNECTION=database

# ─── Broadcasting ────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log

# ─── Filesystem ──────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local            # production: s3

# ─── Redis ───────────────────────────────────────────────────────────────────
# Docker dev: redis:7-alpine (port 6379, no auth)
# production: set REDIS_PASSWORD to match /etc/redis/redis.conf requirepass
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null              # production: <strong password>
REDIS_PORT=6379

# ─── Mail ────────────────────────────────────────────────────────────────────
# Dev: Mailpit (docker-compose service, SMTP 1025, web UI http://localhost:8025)
# production: use Mailgun, Postmark, or SES
#   MAIL_MAILER=mailgun
#   MAILGUN_DOMAIN=mg.expatcarbuyers.com
#   MAILGUN_SECRET=<api key>
#   MAILGUN_ENDPOINT=api.eu.mailgun.net
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@expatcarbuyers.com"
MAIL_FROM_NAME="${APP_NAME}"

# Admin email — receives lead/booking notifications
ADMIN_EMAIL=info@expatcarbuyers.com

# ─── Meilisearch ─────────────────────────────────────────────────────────────
# Dev: docker-compose service on port 7700
# production: Docker container started by bootstrap.sh on 127.0.0.1:7700
#   MEILISEARCH_KEY must match MEILI_MASTER_KEY passed to the container
#   Use a separate search-only API key for NEXT_PUBLIC_MEILI_SEARCH_KEY
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=masterKey        # production: rotate to a strong random key

# ─── Sanctum (API Auth) ──────────────────────────────────────────────────────
# production: www.expatcarbuyers.com,expatcarbuyers.com
SANCTUM_STATEFUL_DOMAINS=localhost:3000

# ─── AWS S3 (production file storage) ────────────────────────────────────────
# Leave empty in local dev — local disk is used instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=                      # production: expatcarbuyers-media (or similar)
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Laravel Horizon ─────────────────────────────────────────────────────────
# Horizon runs as a Forge daemon:
#   Command:  php artisan horizon
#   Dir:      /home/forge/api.expatcarbuyers.com
# production: no extra env vars needed — config is in config/horizon.php
# Horizon dashboard: https://api.expatcarbuyers.com/horizon  (super_admin only)

# ─── Legacy MySQL (ETL source) ───────────────────────────────────────────────
# Used only by: php artisan etl:legacy-bookings
# Leave blank once ETL is complete.
LEGACY_DB_HOST=127.0.0.1
LEGACY_DB_PORT=3306
LEGACY_DB_DATABASE=expatcar_legacy  # actual legacy DB name (check old .env)
LEGACY_DB_USERNAME=root
LEGACY_DB_PASSWORD=

# ─── Maintenance ─────────────────────────────────────────────────────────────
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database
BCRYPT_ROUNDS=12                 # production: 12 (good balance of security/perf)
